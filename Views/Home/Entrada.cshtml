@{
    ViewData["Title"] = "CONTROLE INTELIGENTE DE ESTOQUE";
}

<style>
    /* Área principal com rolagem interna apenas se necessário */
    .main-content {
        flex-grow: 1;
        padding: 20px 40px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
    }

    h2 {
        margin-top: 0;
        margin-bottom: 20px;
        font-size: 24px;
    }

    .container-entrada {
        display: flex;
        gap: 20px;
        max-width: 1200px; /* Limita a largura para não espalhar demais */
    }

    .box {
        background: #1e293b;
        padding: 20px;
        border-radius: 12px;
        border: 1px solid #334155;
        flex: 1;
    }

    .box-preview {
        width: 300px; /* Reduzi um pouco a largura da lateral */
        flex-shrink: 0;
    }

    .scanner-area {
        text-align: center;
        border: 2px dashed var(--accent-orange);
        padding: 20px;
        border-radius: 12px;
        margin-bottom: 20px;
        background: rgba(255, 140, 0, 0.05);
    }

        .scanner-area i {
            font-size: 35px;
            color: var(--accent-orange);
            margin-bottom: 10px;
            display: block;
        }

        .scanner-area p {
            margin: 5px 0;
            font-size: 14px;
        }

    .row {
        display: flex;
        gap: 15px;
        margin-bottom: 20px;
    }

    .form-group {
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    input, select {
        padding: 10px;
        margin-top: 5px;
        background: #0f172a;
        border: 1px solid #334155;
        color: white;
        border-radius: 6px;
        width: 100%;
        box-sizing: border-box;
        font-size: 14px;
    }

    .btn-confirm {
        background: var(--accent-green);
        color: #0f172a;
        border: none;
        padding: 15px;
        width: 100%;
        font-weight: bold;
        border-radius: 8px;
        cursor: pointer;
        font-size: 16px;
    }

    /* Ajuste da imagem para telas menores */
    .product-preview-img {
        width: 100%;
        height: 150px;
        background: #0f172a;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 10px 0;
    }

    .label-desc {
        font-size: 11px;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .info-valor {
        font-size: 16px;
        font-weight: bold;
        margin-bottom: 10px;
    }
</style>


<div class="main-content">
    <h2>NOVA ENTRADA DE MATERIAL</h2>

    <div class="container-entrada">
        <div class="box">
            <div class="scanner-area">
                <i class="fa-solid fa-barcode"></i>
                <p>ESCANEAR CÓDIGO DE BARRAS</p>
                <input type="text" placeholder="Aguardando bip..." autofocus>
            </div>

            <div class="row">
                <div class="form-group" style="flex: 0.5;">
                    <label class="label-desc">Quantidade</label>
                    <input type="number" value="1">
                </div>
                <div class="form-group">
                    <label class="label-desc">Fornecedor</label>
                    <select>
                        <option disabled selected>Selecione um fornecedor</option>
                        <option>Moinho de Trigo S.A.</option>
                        <option>Distribuidora Porto Velho</option>
                    </select>
                </div>
            </div>

            <button class="btn-confirm"><i class="fa-solid fa-check"></i> CONFIRMAR ENTRADA</button>
        </div>

        <div class="box box-preview" style="text-align: center;">
            <p class="label-desc">Identificação do Produto</p>
            <div class="product-preview-img">
                <i class="fa-solid fa-image" style="font-size: 30px; color: #1e293b;"></i>
            </div>
            <p class="label-desc">Produto</p>
            <div class="info-valor">Farinha de Trigo Especial</div>
            <p class="label-desc">Marca</p>
            <div class="info-valor">Rosa Branca</div>
            <p class="label-desc">Estoque Atual</p>
            <div class="info-valor" style="color: var(--accent-orange)">40 Kg</div>
        </div>
    </div>
</div>